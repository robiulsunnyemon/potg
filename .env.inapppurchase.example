# ============================================================
# In-App Purchase Configuration (Google Play & Apple Store)
# ============================================================

# Mock Payment Mode
# Set to 'true' to skip real API verification and grant items immediately for testing.
# Set to 'false' for production.
ENABLE_MOCK_PAYMENT=true

# ------------------------------------------------------------
# Google Play Store Settings
# ------------------------------------------------------------
# The package name of your Android application.
GOOGLE_PACKAGE_NAME=com.robiulsunyemon.lumin

# Absolute path to your Google Service Account JSON file.
# This file must have access to the Google Play Android Developer API.
GOOGLE_SERVICE_ACCOUNT_JSON=C:/path/to/your/google-service-account.json

# ------------------------------------------------------------
# Apple App Store Settings
# ------------------------------------------------------------
# Apple Shared Secret (from App Store Console -> Your App -> App Information)
APPLE_SHARED_SECRET=your_apple_shared_secret_here

# ============================================================
# Instructions:
# 1. Provide the real credentials when they are available from the client.
# 2. To test immediately, keep ENABLE_MOCK_PAYMENT=true.
# 3. Add these variables to your main .env file or load them separately.
# ============================================================
