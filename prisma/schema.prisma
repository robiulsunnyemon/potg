generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}



model User {
  id           String         @id @default(uuid())
  fullName     String
  email        String         @unique
  phoneNumber  String         @unique
  password     String
  isVerified   Boolean        @default(false)
  status       UserStatus     @default(INACTIVE)
  isDeleted    Boolean        @default(false)
  role         Role           @default(USER)
  balance      Int            @default(100)
  profileImage String?
  isPremium    Boolean        @default(false)
  premiumUntil DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  otpCodes     OtpCode[]
  refreshTokens RefreshToken[]
  transactions Transaction[]
  episodeViews EpisodeView[]
  savedEpisodes SavedEpisode[]
  rewardHistory UserRewardHistory[]

  @@map("users")
}

model SavedEpisode {
  id        String   @id @default(uuid())
  userId    String
  episodeId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@map("saved_episodes")
}

enum TransactionType {
  PURCHASE
  SPEND
  REWARD
}

model Transaction {
  id              String          @id @default(uuid())
  userId          String
  seriesId        String?
  episodeId       String?
  amount          Int
  transactionType TransactionType @default(SPEND)
  description     String?
  externalOrderId String?         @unique
  gateway         String?         @default("INTERNAL")
  status          String          @default("SUCCESS")
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id])
  episode         Episode?        @relation(fields: [episodeId], references: [id])

  @@map("transactions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String
  code      String
  purpose   OtpPurpose
  expiresAt DateTime
  isUsed    Boolean    @default(false)
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  FORGET_PASSWORD
}

enum EpisodeUnlockMethod {
  FREE
  COIN
  MEMBER
}

enum AccessControlStatus {
  PUBLIC
  MEMBER
}

enum SeriesStatus {
  DRAFT
  PUBLISHED
}

model Category {
  id     String   @id @default(uuid())
  name   String   @unique
  series Series[]

  @@map("categories")
}

model Language {
  id     String   @id @default(uuid())
  name   String   @unique
  series Series[]

  @@map("languages")
}

model Series {
  id                  String              @id @default(uuid())
  title               String
  description         String
  totalViewers        Int                 @default(0)
  total_false_viewer  Int                 @default(0)
  categoryId          String
  languageId          String
  keywords            String?
  thumbnail           String?
  freeEpisodeLimit    Int?                @default(0)
  episodeUnlockMethod EpisodeUnlockMethod @default(FREE)
  coinPerEpisode      Int?                @default(0)
  accessControlStatus AccessControlStatus @default(PUBLIC)
  status              SeriesStatus        @default(DRAFT)
  isSensitiveContent  Boolean             @default(false)
  tags                String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  category            Category            @relation(fields: [categoryId], references: [id])
  language            Language            @relation(fields: [languageId], references: [id])
  episodes            Episode[]
  ratings             Rating[]

  @@map("series")
}

model Rating {
  id        String   @id @default(uuid())
  userName  String
  userImage String?
  stars     Float
  feedback  String
  seriesId  String
  isActive  Boolean  @default(true)
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("ratings")
}

model Episode {
  id                  String        @id @default(uuid())
  title               String
  seriesId            String
  description         String
  episodeSerialNumber Int
  falseviewers        Int           @default(0)
  thumbnail           String?
  muxAssetId          String?
  muxPlaybackId       String?
  duration            Float?
  resolution          String?       @default("1080p")
  isProcessing        Boolean       @default(true)
  status              SeriesStatus  @default(DRAFT)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  series              Series        @relation(fields: [seriesId], references: [id])
  transactions        Transaction[]
  views               EpisodeView[]
  savedBy             SavedEpisode[]

  @@map("episodes")
}



model EpisodeView {
  id        String   @id @default(uuid())
  episodeId String
  userId    String
  createdAt DateTime @default(now())
  episode   Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("episode_views")
}

enum TargetAudience {
  ALL
  FREE
  VIP
  INACTIVE
  NEW
}

model Notification {
  id              String         @id @default(uuid())
  title           String
  message         String
  targetAudience  TargetAudience @default(ALL)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("notifications")
}

model CoinPackage {
  id           String   @id
  packageName   String
  baseCoins    Int
  bonusCoins   Int      @default(0)
  priceUsd     Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("coin_packages")
}

enum SubscriptionDuration {
  WEEKLY
  MONTHLY
  YEARLY
}

model SubscriptionPlan {
  id           String               @id
  packageName  String
  planName     String
  priceUsd     Float
  duration     SubscriptionDuration
  benefits     String[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@map("subscription_plans")
}

enum RewardDay {
  DAY_ONE
  DAY_TWO
  DAY_THREE
  DAY_FOUR
  DAY_FIVE
  DAY_SIX
  DAY_SEVEN
}

model RewardSetting {
  id         String    @id @default(uuid())
  day        RewardDay @unique
  coins      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("reward_settings")
}

model UserRewardHistory {
  id            String    @id @default(uuid())
  userId        String
  day           RewardDay
  claimedDate   DateTime  @default(now())
  coinsRewarded Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@map("user_reward_history")
}

model AppPage {
  id        String   @id @default(uuid())
  title     String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_pages")
}

model Faq {
  id          String   @id @default(uuid())
  title       String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("faqs")
}
